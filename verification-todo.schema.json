{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agentpatternscatalog/patterns/verification-todo.schema.json",
  "title": "Catalog Verification TODO",
  "description": "One entry per pattern and per framework. Tracks per-aspect verification status so future agents (or contributors) can work through the catalog item-by-item without re-deriving the list each time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["last_analysis_date", "patterns", "frameworks"],
  "properties": {
    "$schema": {"type": "string"},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "last_analysis_date": {"type": "string", "format": "date"},
    "aspect_definitions": {
      "type": "object",
      "description": "Plain-English definitions of each aspect for both pattern and framework entries."
    },
    "patterns": {
      "type": "array",
      "items": {"$ref": "#/$defs/entry_pattern"}
    },
    "frameworks": {
      "type": "array",
      "items": {"$ref": "#/$defs/entry_framework"}
    }
  },
  "$defs": {
    "aspect_status": {
      "type": "string",
      "enum": ["todo", "pass", "fail", "na"]
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "text"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "text": {"type": "string", "minLength": 1},
        "author": {"type": "string"}
      }
    },
    "entry_common": {
      "type": "object",
      "required": ["id", "name", "verified", "aspects"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {"type": "string"},
        "verified": {"type": "boolean"},
        "last_verified": {
          "anyOf": [
            {"type": "string", "format": "date"},
            {"type": "null"}
          ]
        },
        "verifier": {
          "anyOf": [
            {"type": "string"},
            {"type": "null"}
          ]
        },
        "notes": {
          "type": "array",
          "items": {"$ref": "#/$defs/note"}
        }
      }
    },
    "entry_pattern": {
      "allOf": [
        {"$ref": "#/$defs/entry_common"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["category"],
          "properties": {
            "id": true, "name": true, "verified": true,
            "last_verified": true, "verifier": true, "notes": true,
            "category": {"type": "string"},
            "aspects": {
              "type": "object",
              "additionalProperties": {"$ref": "#/$defs/aspect_status"}
            }
          }
        }
      ]
    },
    "entry_framework": {
      "allOf": [
        {"$ref": "#/$defs/entry_common"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": true, "name": true, "verified": true,
            "last_verified": true, "verifier": true, "notes": true,
            "vendor": {"type": "string"},
            "aspects": {
              "type": "object",
              "additionalProperties": {"$ref": "#/$defs/aspect_status"}
            }
          }
        }
      ]
    }
  }
}
