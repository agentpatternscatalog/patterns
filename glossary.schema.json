{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agentpatternscatalog/patterns/glossary.schema.json",
  "title": "Catalog Glossary",
  "description": "Plain-English definitions for terms and acronyms used across the catalog. Pattern pages link these terms inline.",
  "type": "object",
  "additionalProperties": false,
  "required": ["last_analysis_date", "terms"],
  "properties": {
    "$schema": {"type": "string"},
    "title": {"type": "string"},
    "description": {"type": "string"},
    "last_analysis_date": {"type": "string", "format": "date"},
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "term", "gloss"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Stable kebab-case identifier."
          },
          "term": {
            "type": "string",
            "description": "Display form of the term as it appears in pattern text."
          },
          "expansion": {
            "type": "string",
            "description": "Full expansion of an acronym (e.g. 'Retrieval-Augmented Generation' for 'RAG')."
          },
          "gloss": {
            "type": "string",
            "minLength": 20,
            "description": "Plain-English one-paragraph definition aimed at someone who has never seen the term."
          }
        }
      }
    }
  }
}
