{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nissen-consulting/agentic-patterns/patterns.compositions.schema.json",
  "title": "Agentic Patterns — Compositions Reverse Index",
  "description": "Reverse index from pattern_id to the compositions (products, frameworks, agents) that implement it. Derived from compositions-src/*.json members[] entries. Generated by .github/scripts/build_pattern_compositions.py; do not hand-edit.",
  "type": "object",
  "additionalProperties": false,
  "required": ["updated", "patterns"],
  "properties": {
    "$schema": {"type": "string"},
    "updated": {"type": "string", "format": "date"},
    "license": {"type": "string"},
    "source": {"type": "string"},
    "description": {"type": "string"},
    "total_patterns": {"type": "integer", "minimum": 0},
    "total_links": {"type": "integer", "minimum": 0},
    "patterns": {
      "type": "object",
      "description": "Map from pattern_id to a list of compositions that implement it.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["composition_id", "composition_name", "role"],
          "properties": {
            "composition_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            },
            "composition_name": {"type": "string"},
            "kind": {"type": ["string", "null"]},
            "vendor": {"type": ["string", "null"]},
            "role": {
              "type": ["string", "null"],
              "description": "How central the pattern is to the composition."
            },
            "evidence_status": {
              "type": ["string", "null"],
              "description": "Confidence in the link: full, limited, inferred, etc."
            },
            "note": {"type": ["string", "null"]}
          }
        }
      }
    }
  }
}
